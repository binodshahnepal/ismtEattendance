# Supabase Project Configuration URL (from Supabase Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Public Anonymous API Key (from Supabase Settings -> API)
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key
